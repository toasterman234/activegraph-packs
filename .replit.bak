modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3055
externalPort = 3002

[[ports]]
localPort = 3066
externalPort = 5000

[[ports]]
localPort = 5055
externalPort = 3003

[[ports]]
localPort = 5066
externalPort = 6000

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 7788
externalPort = 3000

[[ports]]
localPort = 7799
externalPort = 3001

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[nix]
channel = "stable-25_05"
packages = ["libxcrypt", "libyaml"]
